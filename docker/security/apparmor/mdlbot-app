#include <tunables/global>

profile mdlbot-app flags=(attach_disconnected,mediate_deleted) {
  #include <abstractions/base>
  #include <abstractions/nameservice>

  network inet stream,
  network inet6 stream,
  network inet dgram,
  network inet6 dgram,
  signal,

  deny capability,
  deny mount,
  deny umount,
  deny pivot_root,
  deny ptrace,
  deny /proc/sys/** wklx,
  deny /sys/** wklx,

  /usr/bin/tini ixr,
  /usr/local/bin/mdlbot-entrypoint ixr,
  /usr/local/bin/python* ixr,
  /usr/local/bin/pg_dump ixr,
  /usr/local/bin/pg_restore ixr,
  /usr/bin/curl ixr,
  /usr/bin/openssl ixr,
  /bin/sh ixr,
  /opt/mdlbot/bin/** ixr,
  /opt/mdlbot/** mr,
  /usr/** mr,
  /lib/** mr,
  /lib64/** mr,
  /etc/** r,
  /proc/** r,
  /dev/null rw,
  /dev/urandom r,
  /run/secrets/** r,
  /tmp/** rwk,
  /srv/storage/** rwk,
  /srv/backups/** rwk,
  /var/log/mdlbot/** rwk,
}
